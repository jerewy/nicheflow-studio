# Copy this file to .env for local development.
# Never commit a real API key.

# Required for Groq-backed smart title/caption generation.
GROQ_API_KEY=

# Defaults are kept in code; override only when you intentionally want a different model.
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_ENABLE_VISION=1
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_MAX_FRAMES=3

# Free/basic-safe guardrails used in generation metadata.
# Enforce these in batch tooling/UI before running many videos.
# GROQ_MONTHLY_BUDGET_USD=1.00
# GROQ_MONTHLY_VIDEO_CAP=1000
# GROQ_DAILY_VIDEO_CAP=40
# GROQ_BUDGET_WARN_RATIO=0.8

# Optional local fallback provider. Leave disabled unless Ollama is installed and running.
OLLAMA_DISABLED=1
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://127.0.0.1:11434
